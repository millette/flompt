# ─── AI Provider ─────────────────────────────────────────────────────────────
# Uncomment and fill in according to your provider

# Groq (recommended — fast and free)
# GROQ_API_KEY=gsk_...
# AI_PROVIDER=groq
# AI_MODEL=openai/gpt-oss-120b

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini

# ─── Prompt Guard (security filter) ──────────────────────────────────────────
# llama-guard-3-8b via Groq — analyzes prompts (S1-S13 hazard taxonomy).
# Uses the same GROQ_API_KEY — no additional key required.
# Disable with PROMPT_GUARD_ENABLED=false.
# PROMPT_GUARD_ENABLED=true
